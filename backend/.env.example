# Деплой: на своём ПК в каталоге backend выполните composer update и залейте vendor на хостинг (на сервере composer не обязателен).
# PHP на хостинге: не ниже 7.4.

DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=max_bot

MAX_BOT_TOKEN=
# Логин бота без @ (из GET /me или кабинета) — для кнопки «Открыть» в мини-приложении MAX (type open_app). Пусто = обычная ссылка в браузере.
MAX_BOT_USERNAME=
# Только A–Z, a–z, 0–9, _, - (5–256 символов). Иначе к MAX уходит SHA256(hex) от строки — проверка заголовка совпадает.
MAX_WEBHOOK_SECRET=
# Базовый URL Bot API (документация): https://platform-api.max.ru — только Authorization, без access_token в query
MAX_API_BASE_URL=https://platform-api.max.ru
WEBAPP_URL=https://example.com/webapp
